<div class="toolbar">
  <h1>Editar Peditório</h1>
</div>

<form method="post" action="/peditorios/<%= p.id %>/update" class="card" style="padding:12px">
  <label>Nome da pessoa
    <input type="text" name="nome_pessoa" value="<%= p.nome_pessoa || '' %>" />
  </label><br>

  <label>Local
    <input type="text" name="local" value="<%= p.local || '' %>" />
  </label><br>

  <label>Equipa
    <input type="text" name="equipa" value="<%= p.equipa || '' %>" />
  </label><br>

  <label>Valor prometido (€)
    <input type="number" step="0.01" inputmode="decimal" name="valor_prometido"
           value="<%= ((p.valor_prometido_cents || 0) / 100).toFixed(2) %>" required />
  </label><br>

  <label>Valor entregue (€)
    <input type="number" step="0.01" inputmode="decimal" name="valor_entregue"
           value="<%= ((p.valor_entregue_cents || 0) / 100).toFixed(2) %>" required />
  </label><br>

  <button class="btn">Guardar</button>
  <a class="btn btn-light" href="/peditorios">Cancelar</a>
</form>
