<section class="card">
  <h1>Auditoria de Segurança</h1>
  <p class="muted">Últimos 200 eventos de autenticação.</p>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Data/Hora</th>
          <th>Evento</th>
          <th>Email</th>
          <th>IP</th>
          <th>Meta</th>
        </tr>
      </thead>
      <tbody>
        <% if (!rows.length) { %>
          <tr><td colspan="6">Sem registos.</td></tr>
        <% } %>
        <% rows.forEach(r => { %>
          <tr>
            <td><%= r.id %></td>
            <td><%= r.dt %></td>
            <td><%= r.event %></td>
            <td><%= r.email || '-' %></td>
            <td><%= r.ip || '-' %></td>
            <td style="max-width:320px;white-space:pre-wrap;"><%= r.meta || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

