<section class="card">
  <h1>Auditoria de Segurança</h1>
  <p class="muted">Últimos 200 eventos de autenticação.</p>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;margin:8px 0 12px;">
    <article class="card"><strong>Total (24h)</strong><div><%= stats?.total_24h || 0 %></div></article>
    <article class="card"><strong>Login OK (24h)</strong><div><%= stats?.success_24h || 0 %></div></article>
    <article class="card"><strong>Password errada (24h)</strong><div><%= stats?.bad_password_24h || 0 %></div></article>
    <article class="card"><strong>Rate-limited (24h)</strong><div><%= stats?.rate_limited_24h || 0 %></div></article>
  </div>
  <% if (msg) { %><p class="ok"><%= msg %></p><% } %>
  <form class="inline" method="get" action="/seguranca/audit" style="display:flex;gap:8px;flex-wrap:wrap;align-items:end;margin:10px 0 14px;">
    <div>
      <label for="event">Evento</label><br />
      <input id="event" name="event" value="<%= filters?.event || '' %>" />
    </div>
    <div>
      <label for="q">Pesquisa</label><br />
      <input id="q" name="q" value="<%= filters?.q || '' %>" placeholder="email, ip, meta" />
    </div>
    <div>
      <label for="limit">Limite</label><br />
      <input id="limit" type="number" min="1" max="1000" name="limit" value="<%= filters?.limit || 200 %>" />
    </div>
    <button type="submit" class="btn">Filtrar</button>
    <a class="btn btn-light" href="/seguranca/audit.csv?limit=<%= filters?.limit || 200 %>">Exportar CSV</a>
  </form>
  <form method="post" action="/seguranca/audit/purge" style="display:flex;gap:8px;align-items:end;margin:0 0 14px;">
    <div>
      <label for="days">Apagar registos mais antigos que (dias)</label><br />
      <input id="days" type="number" name="days" min="1" max="3650" value="90" />
    </div>
    <button class="btn btn-danger" type="submit">Purgar</button>
  </form>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Data/Hora</th>
          <th>Evento</th>
          <th>Email</th>
          <th>IP</th>
          <th>Meta</th>
        </tr>
      </thead>
      <tbody>
        <% if (!rows.length) { %>
          <tr><td colspan="6">Sem registos.</td></tr>
        <% } %>
        <% rows.forEach(r => { %>
          <tr>
            <td><%= r.id %></td>
            <td><%= r.dt %></td>
            <td><%= r.event %></td>
            <td><%= r.email || '-' %></td>
            <td><%= r.ip || '-' %></td>
            <td style="max-width:320px;white-space:pre-wrap;"><%= r.meta || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
