<div class="toolbar">
  <h1>Peditórios</h1>
  <a class="btn" style="margin-left:auto" href="/peditorios/new">Novo</a>
</div>

<div class="cards" style="margin-bottom:12px;">
  <div class="card stat">
    <div class="stat-label">Total Prometido</div>
    <div class="stat-number">€ <%= (total_valor_prometido_cents/100).toFixed(2) %></div>
  </div>
  <div class="card stat">
    <div class="stat-label">Total Entregue</div>
    <div class="stat-number">€ <%= (total_valor_entregue_cents/100).toFixed(2) %></div>
  </div>
  <div class="card stat">
    <div class="stat-label">Em Falta</div>
    <div class="stat-number">€ <%= (total_valor_falta_cents/100).toFixed(2) %></div>
  </div>
</div>

<div class="card">
  <h3>Lista</h3>

  <div class="table-wrap">
    <table class="table table--form table--form-manual">
      <thead>
        <tr>
          <th>Pessoa</th>
          <th>Local</th>
          <th>Equipa</th>
          <th>Prometido (€)</th>
          <th>Entregue (€)</th>
          <th>Em falta (€)</th>
          <th style="width:220px">Ações</th>
        </tr>
      </thead>

      <tbody>
        <% if (!itens.length) { %>
          <tr><td colspan="7" class="muted">Sem peditórios registados.</td></tr>
        <% } %>

        <% itens.forEach(p => { const fid = `f-${p.id}`; %>
          <tr>
            <td data-label="Pessoa">
              <input name="nome_pessoa" value="<%= p.nome_pessoa || '' %>" form="<%= fid %>">
            </td>
            <td data-label="Pessoa">
              <input name="nome_pessoa" value="<%= p.nome_pessoa || '' %>" form="<%= fid %>">
            </td>
            <td data-label="Local">
              <input name="local" value="<%= p.local || '' %>" form="<%= fid %>">
            </td>
            <td data-label="Equipa">
              <input name="equipa" value="<%= p.equipa || '' %>" form="<%= fid %>">
            </td>
            <td data-label="Prometido (€)">
              <input name="valor_prometido" inputmode="decimal" step="0.01"
                     value="<%= ((p.valor_prometido_cents||0)/100).toFixed(2) %>"
                     form="<%= fid %>">
            </td>
            <td data-label="Entregue (€)">
              <input name="valor_entregue" inputmode="decimal" step="0.01"
                     value="<%= ((p.valor_entregue_cents||0)/100).toFixed(2) %>"
                     form="<%= fid %>">
            </td>
            <td data-label="Em falta (€)">
              € <%= (((p.valor_prometido_cents||0) - (p.valor_entregue_cents||0))/100).toFixed(2) %>
            </td>
            <td data-label="Ações" class="actions">
              <button class="btn" form="<%= fid %>">Guardar</button>
              <form method="post"
                    action="/peditorios/<%= p.id %>/delete"
                    onsubmit="return confirm('Apagar este peditório?')"
                    style="display:inline">
                <button class="btn btn-danger">Apagar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>

    </table>
  </div>
</div>

<!-- Forms de update (fora da tabela) -->
<% itens.forEach(p => { const fid = `f-${p.id}`; %>
  <form id="<%= fid %>" method="post" action="/peditorios/<%= p.id %>"></form>
<% }) %>
