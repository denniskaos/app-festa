<div class="toolbar">
  <h1>Peditórios</h1>
  <a class="btn" style="margin-left:auto" href="/peditorios/new">Novo</a>
</div>

<div class="cards" style="margin-bottom:12px;">
  <div class="card stat">
    <div class="stat-label">Total Prometido</div>
    <div class="stat-number">€ <%= (total_valor_prometido_cents/100).toFixed(2) %></div>
  </div>
  <div class="card stat">
    <div class="stat-label">Total Entregue</div>
    <div class="stat-number">€ <%= (total_valor_entregue_cents/100).toFixed(2) %></div>
  </div>
  <div class="card stat">
    <div class="stat-label">Em Falta</div>
    <div class="stat-number">€ <%= (total_valor_falta_cents/100).toFixed(2) %></div>
  </div>
</div>

<div class="card">
  <h3>Lista</h3>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Pessoa</th>
          <th>Local</th>
          <th>Equipa</th>
          <th>Prometido (€)</th>
          <th>Entregue (€)</th>
          <th>Em falta (€)</th>
          <th style="width:220px">Ações</th>
        </tr>
      </thead>

      <tbody>
        <% if (!itens.length) { %>
          <tr><td colspan="7" class="muted">Sem peditórios registados.</td></tr>
        <% } %>

        <% itens.forEach(p => { %>
          <tr>
            <td data-label="Pessoa">
              <%= p.nome_pessoa || '—' %>
            </td>
            <td data-label="Local">
              <%= p.local || '—' %>
            </td>
            <td data-label="Equipa">
              <%= p.equipa || '—' %>
            </td>
            <td data-label="Prometido (€)">
              € <%= ((p.valor_prometido_cents||0)/100).toFixed(2) %>
            </td>
            <td data-label="Entregue (€)">
              € <%= ((p.valor_entregue_cents||0)/100).toFixed(2) %>
            </td>
            <td data-label="Em falta (€)">
              € <%= (((p.valor_prometido_cents||0) - (p.valor_entregue_cents||0))/100).toFixed(2) %>
            </td>
            <td data-label="Ações" class="actions">
              <a class="btn btn-light" href="/peditorios/<%= p.id %>/edit">Editar</a>
              <form method="post"
                    action="/peditorios/<%= p.id %>/delete"
                    onsubmit="return confirm('Apagar este peditório?')"
                    style="display:inline">
                <button class="btn btn-danger">Apagar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>

    </table>
  </div>
</div>
