<section class="card">
  <div style="display:flex;justify-content:space-between;gap:12px;align-items:start;flex-wrap:wrap;">
    <div>
      <h1>Recuperações de password</h1>
      <p class="muted">Pedidos que aguardam tratamento administrativo. Nenhum link é guardado nos logs.</p>
    </div>
    <a class="btn btn-light" href="/seguranca/audit">Auditoria</a>
  </div>

  <% if (msg) { %><p class="ok"><%= msg %></p><% } %>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Data/Hora</th>
          <th>Utilizador</th>
          <th>Email</th>
          <th>Estado</th>
          <th>Tratado por</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (!requests.length) { %>
          <tr><td colspan="6">Não existem pedidos de recuperação.</td></tr>
        <% } %>
        <% requests.forEach(request => { %>
          <tr>
            <td><%= request.requested_at %></td>
            <td><%= request.name %></td>
            <td><%= request.email %></td>
            <td>
              <% if (request.status === 'pending') { %>
                <strong>Pendente</strong>
              <% } else if (request.status === 'approved') { %>
                Link gerado
              <% } else { %>
                Resolvido sem link
              <% } %>
            </td>
            <td><%= request.handled_by_name || '-' %></td>
            <td>
              <% if (request.status === 'pending') { %>
                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                  <form method="post" action="/seguranca/password-resets/<%= request.id %>/generate">
                    <button class="btn btn-primary" type="submit">Gerar link</button>
                  </form>
                  <form method="post" action="/seguranca/password-resets/<%= request.id %>/dismiss">
                    <button class="btn btn-light" type="submit">Marcar resolvido</button>
                  </form>
                </div>
              <% } else { %>
                <span class="muted"><%= request.handled_at || '-' %></span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
