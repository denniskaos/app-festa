<div class="toolbar">
  <h1>Painel</h1>
</div>

<% if (user?.role === 'admin' && (pendingPasswordResetCount || 0) > 0) { %>
  <section class="card" style="padding:16px;margin:0 0 16px;border:1px solid #f5c26b;background:#fff7e6;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap">
    <div>
      <strong>Pedidos de recuperação pendentes</strong>
      <p style="margin:4px 0 0;color:#444">
        Tens <%= pendingPasswordResetCount %>
        <%= pendingPasswordResetCount === 1 ? 'pedido pendente' : 'pedidos pendentes' %>
        para tratar.
      </p>
    </div>
    <a class="btn" href="/seguranca/password-resets">Ver pedidos</a>
  </section>
<% } %>

<div class="cards">
  <div class="card stat">
    <div class="stat-number">€ <%= (sumRec/100).toFixed(2) %></div>
    <div class="stat-label">Receitas (movimentos)</div>
  </div>
  <div class="card stat">
    <div class="stat-number">€ <%= (sumDesp/100).toFixed(2) %></div>
    <div class="stat-label">Despesas (movimentos)</div>
  </div>
  <div class="card stat">
    <div class="stat-number">€ <%= (saldoMov/100).toFixed(2) %></div>
    <div class="stat-label">Saldo (movimentos)</div>
  </div>

  <div class="card stat">
    <div class="stat-number">€ <%= (totalPatrocinadores/100).toFixed(2) %></div>
    <div class="stat-label">Patrocinadores</div>
  </div>
  <div class="card stat">
    <div class="stat-number">€ <%= (totalPeditorios/100).toFixed(2) %></div>
    <div class="stat-label">Peditórios</div>
  </div>
  <div class="card stat">
    <div class="stat-number">€ <%= (totalLeiloes/100).toFixed(2) %></div>
    <div class="stat-label">Leilões recebidos</div>
  </div>
  <div class="card stat">
    <div class="stat-number">€ <%= (totalLugaresPago/100).toFixed(2) %></div>
    <div class="stat-label">Lugares recebidos</div>
  </div>
  <div class="card stat">
    <div class="stat-number"><strong>€ <%= (saldoFinal/100).toFixed(2) %></strong></div>
    <div class="stat-label"><strong>Saldo Final</strong></div>
  </div>

  <div class="card stat">
    <div class="stat-number">€ <%= (orcamentoTotal/100).toFixed(2) %></div>
    <div class="stat-label">Orçamento (serviços)</div>
  </div>
  <div class="card stat">
    <div class="stat-number">€ <%= (totalCasa/100).toFixed(2) %></div>
    <div class="stat-label">Em casa (casais)</div>
  </div>
  <div class="card stat">
    <div class="stat-number">€ <%= (desvioOrcamento/100).toFixed(2) %></div>
    <div class="stat-label">Desvio vs Orçamento</div>
  </div>
  <div class="card stat">
    <div class="stat-number"><%= execucaoOrcamentoPct.toFixed(1) %>%</div>
    <div class="stat-label">Execução de Despesa vs Orçamento</div>
  </div>
</div>
