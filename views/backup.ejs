<!-- views/backup.ejs -->
<div class="toolbar">
  <div>
    <h1 style="margin:0;"><%= typeof title !== 'undefined' ? title : 'Backup' %></h1>
    <div class="muted" style="margin-top:4px;">Gestão de exportações e cópias de segurança.</div>
  </div>
  <a class="btn btn-light" href="/dashboard" style="margin-left:auto">Voltar</a>
</div>

<%
  const totalTabelas = (tables || []).length;
  const totalRegistos = (tables || []).reduce((acc, t) => acc + Number((counts && counts[t.name]) || 0), 0);
%>

<div class="cards stats-cards" style="margin-bottom:12px;">
  <div class="card stat card-accent card-accent-blue">
    <div class="stat-label">Base de dados</div>
    <div class="stat-number stat-path">
      <%= dbPath || '(caminho indisponível)' %>
    </div>
  </div>
  <div class="card stat card-accent card-accent-green">
    <div class="stat-label">Tabelas</div>
    <div class="stat-number"><%= totalTabelas %></div>
  </div>
  <div class="card stat card-accent card-accent-gold">
    <div class="stat-label">Total de registos</div>
    <div class="stat-number"><%= totalRegistos %></div>
  </div>
</div>

<div class="card backup-section" style="margin-bottom:12px;">
  <h3 style="margin-top:0; margin-bottom:4px;">Exportar / Download</h3>
  <div class="muted" style="margin-bottom:12px;">Formatos completos para arquivo e partilha.</div>
  <div class="actions-grid">
    <a class="btn btn-primary" href="/backup/download" title="Download direto do ficheiro .db">Descarregar DB</a>
    <a class="btn" href="/backup/export.xlsx">Exportar XLSX</a>
    <a class="btn btn-light" href="/backup/export/all-csv.zip">ZIP com todos os CSVs</a>
    <a class="btn btn-light" href="/backup/export.json">Exportar JSON</a>
    <a class="btn btn-light" href="/backup/export.sql">Exportar SQL</a>
  </div>
</div>

<div class="card backup-section" style="margin-bottom:12px;">
  <h3 style="margin-top:0; margin-bottom:4px;">CSV rápidos</h3>
  <div class="muted" style="margin-bottom:12px;">Exportação imediata por área.</div>
  <div class="actions-grid">
    <a class="btn btn-light" href="/backup/export/movimentos.csv">Movimentos CSV</a>
    <a class="btn btn-light" href="/backup/export/jantares.csv">Jantares CSV</a>
    <a class="btn btn-light" href="/backup/export/orcamento.csv">Orçamento CSV</a>
    <a class="btn btn-light" href="/backup/export/patrocinadores.csv">Patrocinadores CSV</a>
    <a class="btn btn-light" href="/backup/export/peditorios.csv">Peditórios CSV</a>
    <a class="btn btn-light" href="/backup/export/casais.csv">Casais CSV</a>
  </div>
</div>

<div class="card backup-section">
  <h3 style="margin-top:0">Tabelas na base de dados</h3>

  <% 
    // mapeia nomes para CSVs rápidos (quando existirem rotas dedicadas)
    const csvMap = {
      movimentos: '/backup/export/movimentos.csv',
      jantares: '/backup/export/jantares.csv',
      orcamento_servicos: '/backup/export/orcamento.csv',
      patrocinadores: '/backup/export/patrocinadores.csv',
      peditorios: '/backup/export/peditorios.csv',
      casais: '/backup/export/casais.csv',
    };
  %>

  <table class="table backup-table">
    <thead>
      <tr>
        <th style="width:220px">Tabela</th>
        <th style="width:120px">Registos</th>
        <th>DDL</th>
        <th style="width:170px">Ação</th>
      </tr>
    </thead>
    <tbody>
      <% if (!tables || !tables.length) { %>
        <tr><td colspan="4" class="muted">Sem tabelas encontradas.</td></tr>
      <% } %>
      <% (tables || []).forEach(t => { %>
        <tr>
          <td><code><%= t.name %></code></td>
          <td><strong><%= (counts && typeof counts[t.name] !== 'undefined') ? counts[t.name] : '—' %></strong></td>
          <td>
            <details>
              <summary>Ver estrutura SQL</summary>
              <pre style="white-space:pre-wrap; margin:6px 0;"><%= t.sql || '(sem DDL disponível)' %></pre>
            </details>
          </td>
          <td>
            <% if (csvMap[t.name]) { %>
              <a class="btn btn-light" href="<%= csvMap[t.name] %>">Exportar CSV</a>
            <% } else { %>
              <span class="pill-muted">Sem CSV direto</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<style>
  .backup-section {
    border: 1px solid var(--border, #e5e7eb);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.03);
  }

  .stats-cards .card {
    min-height: 88px;
  }

  .card-accent {
    border-top: 3px solid transparent;
  }
  .card-accent-blue { border-top-color: #3b82f6; }
  .card-accent-green { border-top-color: #10b981; }
  .card-accent-gold { border-top-color: #f59e0b; }

  .stat-path {
    font-size: 14px;
    line-height: 1.2;
    word-break: break-all;
  }

  .actions-grid {
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  }

  .actions-grid .btn {
    text-align: center;
    font-weight: 600;
    border-radius: 999px;
    padding: 8px 14px;
  }

  .backup-table tbody tr:nth-child(odd) {
    background: rgba(15, 23, 42, 0.02);
  }

  .pill-muted {
    display: inline-block;
    padding: 5px 10px;
    border-radius: 999px;
    background: #f3f4f6;
    color: #6b7280;
    font-size: 12px;
    font-weight: 600;
  }

  /* ajustes para mobile */
  @media (max-width: 640px) {
    .actions-grid { grid-template-columns: 1fr; }
    table.table code { word-break: break-all; }
  }
</style>
